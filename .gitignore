# build output
build/
build-*/
*.o
*.a
*.so

# meson-generated subproject artifacts (deps are vendored via git submodules)
/subprojects/.wraplock
/subprojects/packagecache/

# local CSH APM install target
local/
*.bin

# stray npm artifacts (accidental `npm install bun` — bun is global via brew now;
# safe to delete: rm -rf node_modules package.json package-lock.json)
node_modules/
package.json
package-lock.json

# local-only notes (private team internals / unreported issues)
*.local.md

# editor / OS
.DS_Store
compile_commands.json
.cache/

# Capture outputs. Most files under captures/ are reproducible scratch: per-pass
# oracle traces (converge_*, deploy_*, dbg_*), live-bus snapshots (can0_*), and
# debug runs. Those stay untracked — they regenerate from the scripts.
#
# The exception is the HEADLINE EVIDENCE: the sweep result tables and the written
# findings. These are the thesis deliverable, they cost flatsat hardware + hours
# to regenerate, and they are the one thing that must survive a disk loss. So we
# ignore the directory and explicitly negate the evidence back in.
captures/*
!captures/*_sweep.csv
!captures/rq3_corruption.csv
!captures/flight_dtp_*.csv
!captures/*_finding.md

# stray VM memory dumps (flatsat sim scratch; not part of the instrument)
*.vmem

# scratch from unzipping mission .ods/.xlsx during research (not part of the repo)
.tmp_extract/

# python tooling (scripts/)
__pycache__/
*.pyc
.gstack/
