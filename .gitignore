# build output
build/
build-*/
*.o
*.a
*.so

# meson-generated subproject artifacts (deps are vendored via git submodules)
/subprojects/.wraplock
/subprojects/packagecache/

# local CSH APM install target
local/
*.bin

# stray npm artifacts (accidental `npm install bun` — bun is global via brew now;
# safe to delete: rm -rf node_modules package.json package-lock.json)
node_modules/
package.json
package-lock.json

# local-only notes (private team internals / unreported issues)
*.local.md

# editor / OS
.DS_Store
compile_commands.json
.cache/
captures/

# stray VM memory dumps (flatsat sim scratch; not part of the instrument)
*.vmem

# python tooling (scripts/)
__pycache__/
*.pyc
