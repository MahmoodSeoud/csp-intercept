#!/usr/bin/env bash
# rawdtp-point - ONE cell of the H2 "raw DTP" arm.
#
# Raw DTP = libdtp's native interval re-request, WITHOUT satDeploy's selective-repeat/
# sha256/cross-session wrapper. Same libdtp + same session_hooks as the deployed DIPP
# receiver; the ONLY difference from DIPP (fire-and-forget) is that we invoke resume.
#
# Mechanism per cell: pull the pinned payload from the DTP server (upload_gs-server,
# addr 5424) with `dtp_client`; pass 1 = fresh, passes 2..N = `dtp_client -r` (resume:
# re-requests ONLY the missing intervals from the saved dtp_session_meta.bin). Fresh
# injector seed each pass (gaps fill probabilistically -> converges, exactly as satDeploy).
# Stop when dtp_info reports Missing: 0 (COMPLETE) or MAX_PASSES (INCOMPLETE).
#
# Receiver is HOST-SIDE on can0 (x86): dtp_client writes dtp_data.bin + dtp_session_meta.bin
# in its cwd, so completion (dtp_info Missing) and integrity (sha256 vs original) are read
# host-side, no OBC needed. Paced at 9.6 kbit/s so the receiver cannot overrun (no
# receiver-side loss confound). Loss is injected on the server data plane (port 8) only.
#
# Output (stdout, last line): RESULT <passes> <total_injected> <total_dropped> <result> <sha_ok>
# Usage: rawdtp-point <loss> <seed> <label>     e.g.  rawdtp-point 0.10 1 dtp_L0.10_s1
set -uo pipefail
LOSS="${1:?loss}"; SEED="${2:?seed}"; LABEL="${3:?label}"
MTU="${MTU:-256}"; OVH="${OVH:-4}"; SRV_ADDR="${SRV_ADDR:-5424}"; RCV_ADDR="${RCV_ADDR:-16}"
THR="${THR:-1024}"; MAX_PASSES="${MAX_PASSES:-12}"
REPO=/home/mseo/thesis/csp-intercept
CAP="$REPO/captures"
CSH=/home/mseo/thesis/csh/builddir/csh
INJ="$REPO/build/tests/e2e/ci_inject_bridge"
MONSO="$REPO/build/apm/libcsh_csp_monitor.so"
UPSO=/home/mseo/.local/lib/csh/libcsh_dtp_client.so
PAY="$CAP/payload_256k.bin"
ORIG_SHA=$(awk '/sha256:/{print $2}' "$CAP/payload_256k.manifest")
PSIZE=$(stat -c%s "$PAY"); PAYLOAD=$((MTU-OVH)); TOTAL=$(( (PSIZE + PAYLOAD - 1) / PAYLOAD ))

RATE_BPS="${RATE_BPS:-4800}"
PACE_US=$(( RATE_BPS > 0 ? MTU * 8 * 1000000 / RATE_BPS : 0 ))
SER_S=$(( TOTAL * PACE_US / 1000000 ))
PASS_TO=$(( SER_S + 90 )); [ "$PASS_TO" -lt 60 ] && PASS_TO=60
INJ_TO=$(( PASS_TO + 30 ))
CLI_SLEEP_MS=$(( (SER_S + 45) * 1000 ))

# preflight
ss -ltn 2>/dev/null | grep -q ':6000' || { echo "FAIL: broker (6000) down"; exit 1; }
pgrep -f 'upload_gs-server -z 127.0.0.1 -a 5424' >/dev/null || { echo "FAIL: upload_gs-server (-z loopback) down"; exit 1; }
if pgrep -af 'upload_gs-server -c can0' >/dev/null 2>&1; then echo "FAIL: stray root upload_gs-server -c can0 still up (collides 5424) — sudo kill it"; exit 1; fi
[ -f "$UPSO" ] || { echo "FAIL: uploader APM (dtp_client) not at $UPSO"; exit 1; }
if pgrep -x ci_inject_bridge >/dev/null 2>&1; then echo "FAIL: a ci_inject_bridge is already running:"; pgrep -ax ci_inject_bridge; exit 1; fi

# isolated working dir so dtp_data.bin + dtp_session_meta.bin are per-cell
WORK=$(mktemp -d /tmp/rawdtp_${LABEL}_XXXX)
APMDIR="$WORK/apm"; mkdir -p "$APMDIR"; cp "$UPSO" "$APMDIR/"
ORA="$CAP/${LABEL}_oracleA.csv"; : > "$ORA"   # cumulative across passes (append)

total_inj=0; total_drop=0; result=INCOMPLETE; passes=0; missing=$PSIZE
echo "[$LABEL] raw-DTP pull: file=$TOTAL frags, pace=${PACE_US}us (~${SER_S}s/full pass), max ${MAX_PASSES} passes"

attempt=0
while [ "$passes" -lt "$MAX_PASSES" ]; do
  attempt=$((attempt+1)); pidx=$((passes+1))
  pseed=$(( SEED*100 + pidx ))            # distinct, deterministic per pass
  resume_flag=""; [ "$pidx" -gt 1 ] && resume_flag="-r"
  # per-pass loss: RESUME_LOSS overrides loss on passes >1 (isolation test).
  passloss="$LOSS"; [ "$pidx" -gt 1 ] && passloss="${RESUME_LOSS:-$LOSS}"
  pora="$WORK/oracleA_p${pidx}.csv"

  # injector (oracle A) for this pass, fresh seed
  timeout "$INJ_TO" "$INJ" zmq:tcp://127.0.0.1:6000,tcp://127.0.0.1:7000,"$RCV_ADDR" can:can0 8 "$MTU" "$OVH" "$passloss" 4 "$pseed" "$pora" "$SRV_ADDR" "$PACE_US" >"$WORK/inj_p${pidx}.log" 2>&1 &
  INJPID=$!
  sleep 3

  # raw-DTP receiver: one pull (resume on p>1), cwd=$WORK so state lands there
  INIT="$WORK/cli_p${pidx}.csh"
  {
    echo "csp init"; echo "csp add can -c can0 -b 0 -d ${RCV_ADDR}"; echo "apm load -p $APMDIR"
    echo "dtp_client -n $SRV_ADDR -i 0 -m $MTU -t $THR $resume_flag"
    echo "sleep 3000"; echo "dtp_info"; echo "sleep 1000"; echo "exit"
  } > "$INIT"
  ( cd "$WORK" && timeout "$PASS_TO" script -qec "$CSH -i $INIT" /dev/null </dev/null ) >"$WORK/cli_p${pidx}.log" 2>&1 || true

  kill "$INJPID" 2>/dev/null; wait "$INJPID" 2>/dev/null || true

  # per-pass oracle A accounting (col6=frag idx, col8=dropped flag)
  p_inj=$(awk -F, '!/^#/{print $6}' "$pora" 2>/dev/null | sort -nu | grep -c .)
  p_drop=$(awk -F, '!/^#/ && $8==1{print $6}' "$pora" 2>/dev/null | sort -nu | grep -c .)
  total_inj=$((total_inj + p_inj)); total_drop=$((total_drop + p_drop))
  grep -v '^#' "$pora" 2>/dev/null >> "$ORA" || true

  # GUARD: pass 1 with zero data forwarded = server down / no transfer. An empty
  # session reads payload_size=0,bytes_received=0 -> Missing=0-0=0, which would
  # FALSE-POSITIVE as DELIVERED. Abort the cell (no RESULT line -> sweep skips it).
  if [ "$pidx" = "1" ] && [ "$p_inj" = "0" ]; then
    echo "[$LABEL] FAIL: pass 1 transferred 0 frags (server down / no data) — invalid cell, not recorded"
    rm -rf "$WORK"; exit 3
  fi

  # completion from the receiver's own interval accounting (dtp_info: "Missing: N")
  # strip the CR that `script`'s pty appends, plus any stray space -> clean integer
  missing=$(awk -F': *' '/Missing:/{print $2; exit}' "$WORK/cli_p${pidx}.log" 2>/dev/null | tr -dc '0-9')
  missing="${missing:-NA}"
  passes=$pidx
  echo "  pass $pidx: seed=$pseed injected=$p_inj dropped=$p_drop  Missing=${missing} bytes"
  [ "$missing" = "0" ] && { result=DELIVERED; break; }
done

# integrity (raw DTP has NO sha256 verify; test whether interval-complete => correct bytes)
sha_ok=NA
RECV="$WORK/dtp_data.bin"
if [ -f "$RECV" ]; then
  got=$(sha256sum "$RECV" | cut -d' ' -f1)
  [ "$got" = "$ORIG_SHA" ] && sha_ok=MATCH || sha_ok=MISMATCH
  cp "$RECV" "$CAP/${LABEL}_received.bin" 2>/dev/null || true
fi

ovh=$(awk -v t=$total_inj -v f=$TOTAL 'BEGIN{if(f)printf "%.2f", t/f; else print "NA"}')
echo "[$LABEL] loss=$LOSS seed=$SEED -> passes=$passes injected=$total_inj dropped=$total_drop overhead=${ovh}x result=$result sha=$sha_ok"
echo "RESULT $passes $total_inj $total_drop $result $sha_ok"
[ -n "${KEEP_WORK:-}" ] && echo "[$LABEL] work dir kept: $WORK" || rm -rf "$WORK"
