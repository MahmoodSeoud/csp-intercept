#!/usr/bin/env bash
# svu-board-sweep - the fidelity-matched SVU arm: server runs ON the real payload board
# (aarch64, node 5498), ground client pulls DOWNLINK through the loss injector.
#
# Unlike svu-sweep (host-to-host), the data source here is the on-board svu_server, so the
# injector runs INVERTED: ingress=can0 (board side), egress=zmq (ground client), dropping
# the board server's SVU-data frames (dport 9, src=5498). Client requests return clean.
# This gives the SVU arm the SAME on-hardware fidelity as the RDP arm (which hits node 5430).
#
# Precondition: svu_server already running on the board at 5498 (launched via mng_dipp),
# serving a KNOWN file whose exact bytes are in $ORACLE (a prior clean pull). Broker on 6000/7000.
#
# Metric per cell: does the on-board->ground pull complete VERIFIED, in how many rounds, and
# does the result match the known bytes (external oracle)? SILENT CORRUPTION == VERIFIED & sha
# MISMATCH (expected never — the SVU manifest gates every block).
# Output CSV: captures/svu_board_sweep.csv
# Usage: svu-board-sweep ["0.02 0.05 0.10 0.20 0.30"] [nseeds]
set -uo pipefail
LOSSES="${1:-0.02 0.05 0.10 0.20 0.30}"; NSEEDS="${2:-3}"
SRV="${SRV:-5498}"; CLI=5496; DPORT=9; MTU=200; OVH=8; BLOCK=4096; BURST="${BURST:-4}"
REPO=/home/mseo/thesis/csp-intercept
INJ="$REPO/build/tests/e2e/ci_inject_bridge"; CLIENT="$REPO/build-fe/svu/svu_client"
ORACLE="${ORACLE:-/tmp/board_pull.bin}"
[ -f "$ORACLE" ] || { echo "FAIL: oracle $ORACLE missing (do a clean pull first)"; exit 1; }
ORACLE_SHA=$(sha256sum "$ORACLE" | cut -d' ' -f1); SIZE=$(stat -c%s "$ORACLE")
ss -ltn 2>/dev/null | grep -q ':6000' || { echo "FAIL: broker 6000 down"; exit 1; }
CSV="$REPO/captures/svu_board_sweep.csv"
[ -f "$CSV" ] || echo "loss,seed,injected,dropped,claimed,rounds,sha,size,ts" > "$CSV"
echo "svu-board-sweep: board server=$SRV size=${SIZE}B losses=[$LOSSES] nseeds=$NSEEDS"
for loss in $LOSSES; do
  for s in $(seq 1 "$NSEEDS"); do
    L="svuboard_L${loss}_s${s}"; ORA="$REPO/captures/${L}_oracleA.csv"; OUT="/tmp/${L}_out.bin"; rm -f "$OUT"
    if pgrep -f 'tests/e2e/ci_inject_bridge' >/dev/null; then echo "[$L] injector busy, skip"; continue; fi
    "$INJ" can:can0 zmq:tcp://127.0.0.1:6000,tcp://127.0.0.1:7000,$SRV $DPORT $MTU $OVH "$loss" $BURST "$s" "$ORA" $SRV 0 >/tmp/${L}_inj.log 2>&1 &
    INJPID=$!; sleep 3
    out=$(timeout 120 "$CLIENT" -z 127.0.0.1 -a $CLI -C $SRV -o "$OUT" -b $BLOCK -m $MTU 2>&1)
    kill "$INJPID" 2>/dev/null; wait "$INJPID" 2>/dev/null || true
    claimed=INCOMPLETE; rounds='?'
    if echo "$out" | grep -qE "VERIFIED $SIZE bytes"; then claimed=VERIFIED; rounds=$(echo "$out"|grep -oE 'in [0-9]+ round'|grep -oE '[0-9]+'|head -1); fi
    inj=$(awk -F, '!/^#/{c++} END{print c+0}' "$ORA" 2>/dev/null); drp=$(awk -F, '!/^#/ && $8==1{c++} END{print c+0}' "$ORA" 2>/dev/null)
    got=$(sha256sum "$OUT" 2>/dev/null | cut -d' ' -f1); sha=MISMATCH; [ "$got" = "$ORACLE_SHA" ] && sha=MATCH
    gsz=$(stat -c%s "$OUT" 2>/dev/null || echo 0)
    v=""; [ "$claimed" = VERIFIED ] && [ "$sha" = MISMATCH ] && v=" *** SILENT CORRUPTION ***"
    ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    echo "$loss,$s,$inj,$drp,$claimed,${rounds:-?},$sha,$gsz,$ts" >> "$CSV"
    echo "[$L] claimed=$claimed rounds=${rounds:-?} sha=$sha (inj=$inj drop=$drp)$v"
  done
done
echo "=== svu_board_sweep.csv ==="; column -t -s, "$CSV" 2>/dev/null || cat "$CSV"
echo "--- completion (VERIFIED at every cell) ---"; awk -F, 'NR>1{n++;if($5=="VERIFIED")v++} END{print v+0"/"n+0" VERIFIED"}' "$CSV"
echo "--- silent-corruption (VERIFIED & sha MISMATCH, expect 0) ---"; awk -F, 'NR>1 && $5=="VERIFIED" && $7=="MISMATCH"{c++} END{print (c+0)}' "$CSV"
