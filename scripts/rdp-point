#!/usr/bin/env bash
# rdp-point - ONE cell of the RDP/CSH upload arm (RQ3 integrity differential vs DTP).
#
# The deployed software-upload path is CSH `upload`, which runs over CSP RDP
# (reliable: retransmit + window) with libparam vmem_upload's per-packet CRC32
# (csp_connect ... VMEM_PORT_SERVER ... CSP_O_CRC32). Hypothesis: under forward
# loss it NEVER silently corrupts -- it either delivers intact (CRC verifies) or
# fails loudly. Contrast the DTP data plane (port 8, no integrity), which under
# the same loss reports success while delivering a corrupt binary (RQ3).
#
# Wiring (mirrors satdeploy-sweep): ground csh on zmq(5450) -> zmqproxy-lossy
# (6000/7000) -> ci_inject_bridge (drops forward RDP packets to dport=14, keyed
# on RDP sequence number) -> can0 -> node 5430's VMEM region. ACKs return clean
# (forward-loss config). RDP retransmits dropped segments using the clean ACKs.
#
# Per cell: pre-fill the region with zeros over a CLEAN path (so a partial/failed
# upload cannot false-pass on stale correct bytes), upload the pinned 256 KiB
# payload through the lossy injector, then verify on a CLEAN path with TWO oracles:
#   - crc32 (the mechanism's own integrity check)            [mechanism oracle]
#   - download-back + sha256 vs the original                 [external oracle]
# plus the injector drop-log                                 [oracle A]
#
# Output (last line): RESULT <loss> <seed> <injected> <dropped> <claimed> <crc> <sha>
#   claimed = DELIVERED (upload printed "Uploaded <size> bytes") | FAILED
#   crc     = SUCCESS | MISMATCH        (clean post-upload crc32)
#   sha     = MATCH | MISMATCH          (clean download-back vs original, AUTHORITATIVE)
#   SILENT CORRUPTION == claimed DELIVERED & sha MISMATCH (sha is the authoritative
#     external oracle; crc is reported alongside but UNKNOWN reads collapse to MISMATCH).
#     Expected: never.
# Usage: rdp-point <loss> <seed> <label>      e.g.  rdp-point 0.10 7 rdp_L0.10_s7
set -uo pipefail
LOSS="${1:?loss}"; SEED="${2:?seed}"; LABEL="${3:?label}"
NODE="${NODE:-5430}"; DPORT="${DPORT:-14}"; UADDR="${UADDR:-5450}"
MTU="${MTU:-256}"; OVH="${OVH:-8}"; PACE_US="${PACE_US:-0}"   # integrity is rate-independent; default unpaced
REPO=/home/mseo/thesis/csp-intercept
CAP="$REPO/captures"; PAY="$CAP/payload_256k.bin"
SIZE=$(stat -c%s "$PAY"); ORIG_SHA=$(awk '/sha256:/{print $2}' "$CAP/payload_256k.manifest")
INJ="$REPO/build/tests/e2e/ci_inject_bridge"
CSH=/home/mseo/thesis/disco/src/csh/builddir/csh
ZER=/tmp/zeros_${SIZE}.bin; [ -f "$ZER" ] || head -c "$SIZE" /dev/zero > "$ZER"

# preflight
ss -ltn 2>/dev/null | grep -q ':6000' || { echo "FAIL: zmqproxy broker (6000) down"; exit 1; }
[ -x "$INJ" ] || { echo "FAIL: injector not built at $INJ"; exit 1; }
if pgrep -x ci_inject_bridge >/dev/null 2>&1; then echo "FAIL: a ci_inject_bridge already running"; exit 1; fi

run_csh() { local init="$1" to="$2"; timeout "$to" script -qec "$CSH -i $init" /dev/null </dev/null 2>&1; }

# discover the current VMEM region 3 (cmd_s, 256 KiB) address on NODE (moves on node restart)
DISC=$(mktemp /tmp/${LABEL}_disc_XXXX.csh)
{ echo "csp init"; echo "csp add can -d 20"; echo "vmem -n $NODE -v 2 -t 3000"; echo "exit"; } > "$DISC"
REGION=$(run_csh "$DISC" 30 | awk '/cmd_s/{print $3; exit}'); rm -f "$DISC"
[ -n "$REGION" ] || { echo "FAIL: could not read cmd_s region addr from node $NODE (is it up?)"; exit 2; }
echo "[$LABEL] node=$NODE region=$REGION size=$SIZE loss=$LOSS seed=$SEED pace=${PACE_US}us"

# helper: clean crc32 of region vs file -> echoes SUCCESS|FAILURE|UNKNOWN (1 retry)
crc_check() { # $1=file
  local f="$1" out
  for _try in 1 2; do
    local c; c=$(mktemp /tmp/${LABEL}_crc_XXXX.csh)
    { echo "csp init"; echo "csp add can -d 20"; echo "crc32 -n $NODE -v 2 -f $f $REGION"; echo "exit"; } > "$c"
    out=$(run_csh "$c" 60); rm -f "$c"
    echo "$out" | grep -qiE "Success"  && { echo SUCCESS; return; }
    echo "$out" | grep -qiE "Failure"  && { echo FAILURE; return; }
    sleep 2
  done
  echo UNKNOWN
}

# 1) CLEAN pre-fill with zeros (direct can0), CONFIRM it took (region must != payload)
for _pf in 1 2 3; do
  PF=$(mktemp /tmp/${LABEL}_pf_XXXX.csh)
  { echo "csp init"; echo "csp add can -d 20"; echo "upload -n $NODE -v 2 -t 1000 $ZER $REGION"; echo "exit"; } > "$PF"
  run_csh "$PF" 120 >/dev/null; rm -f "$PF"; sleep 2
  pf_vs_payload=$(crc_check "$PAY")           # expect FAILURE (region=zeros != payload)
  [ "$pf_vs_payload" = FAILURE ] && break
  echo "[$LABEL] pre-fill attempt $_pf not confirmed (crc vs payload=$pf_vs_payload), retrying"
done
[ "$pf_vs_payload" = FAILURE ] || { echo "[$LABEL] FAIL: could not establish clean pre-fill (stale-data risk) — cell invalid"; exit 4; }

# 2) lossy injector (forward RDP drops on dport=14), active during the upload only
ORA="$CAP/${LABEL}_oracleA.csv"
"$INJ" zmq:tcp://127.0.0.1:6000,tcp://127.0.0.1:7000,"$NODE" can:can0 "$DPORT" "$MTU" "$OVH" "$LOSS" 4 "$SEED" "$ORA" "$UADDR" "$PACE_US" >"/tmp/${LABEL}_inj.log" 2>&1 &
INJPID=$!; sleep 3

# 3) lossy RDP upload via zmq(UADDR) -> injector -> can0 -> NODE
UP=$(mktemp /tmp/${LABEL}_up_XXXX.csh)
{ echo "csp init"; echo "csp add zmq -d $UADDR 127.0.0.1"
  echo "upload -n $NODE -v 2 -t 3000 $PAY $REGION"; echo "exit"; } > "$UP"
UPOUT=$(run_csh "$UP" 600); rm -f "$UP"
claimed=FAILED; echo "$UPOUT" | grep -qiE "Uploaded $SIZE bytes" && claimed=DELIVERED

kill "$INJPID" 2>/dev/null; wait "$INJPID" 2>/dev/null || true
inj=$(awk -F, '!/^#/{c++} END{print c+0}' "$ORA" 2>/dev/null)
drop=$(awk -F, '!/^#/ && $8==1{c++} END{print c+0}' "$ORA" 2>/dev/null)
sleep 3   # let the RDP connection on NODE fully tear down before clean reads

# 4) CLEAN verification (direct can0): crc32 (mechanism oracle) + download-back sha256 (external oracle, authoritative)
crc=$( [ "$(crc_check "$PAY")" = SUCCESS ] && echo SUCCESS || echo MISMATCH )
sha=MISMATCH
for _dl in 1 2; do
  GOT="/tmp/${LABEL}_got.bin"
  DL=$(mktemp /tmp/${LABEL}_dl_XXXX.csh)
  { echo "csp init"; echo "csp add can -d 20"; echo "download -n $NODE -v 2 -t 1000 $REGION $SIZE $GOT"; echo "exit"; } > "$DL"
  run_csh "$DL" 120 >/dev/null; rm -f "$DL"
  got_sha=$(sha256sum "$GOT" 2>/dev/null | cut -d' ' -f1); rm -f "$GOT"
  [ "$got_sha" = "$ORIG_SHA" ] && { sha=MATCH; break; }
  sleep 2
done

# Authoritative silent-corruption test: mechanism CLAIMED success but external oracle says wrong bytes.
verdict=OK
[ "$claimed" = DELIVERED ] && [ "$sha" = MISMATCH ] && verdict="*** SILENT CORRUPTION ***"
echo "[$LABEL] claimed=$claimed crc=$crc sha=$sha injected=$inj dropped=$drop  $verdict"
echo "RESULT $LOSS $SEED $inj $drop $claimed $crc $sha"
