#!/usr/bin/env bash
# dipp-sweep - Arm A (deployed dipp upload) loss sweep over scripts/upload-point.
#
# Grid: LOSSES x SEEDS, one real upload per point on can0. Appends one row per run
# to captures/dipp_sweep.csv and is RESUMABLE: a (loss,seed) already present in the
# CSV is skipped, so the sweep can be re-run after an interruption.
#
# Delivery metric = oracle A (kept/total; fire-and-forget so kept == delivered,
# kernel TX verified lossless). Oracle B recorded as sanity only.
#
# Usage: dipp-sweep            # full grid
#        LOSSES="0.10" SEEDS="1" dipp-sweep   # subset
set -uo pipefail
REPO=/home/mseo/thesis/csp-intercept
OUT="$REPO/captures/dipp_sweep.csv"
LOSSES="${LOSSES:-0 0.02 0.05 0.10 0.20 0.30}"
SEEDS="${SEEDS:-1 2 3 4 5}"
TOTAL_FRAGS=1041   # 256 KiB at MTU 256 / overhead 4
# Outer per-point ceiling must cover upload-point's paced capture window
# (monitor MON_TO = SER_S+120) plus client-restart + bus-settle setup. Mirror the
# pacing math here so the wrapper scales with RATE_BPS. Set RATE_BPS large for line rate.
RATE_BPS="${RATE_BPS:-9600}"
PACE_US=$(( RATE_BPS > 0 ? 256 * 8 * 1000000 / RATE_BPS : 0 ))
SER_S=$(( TOTAL_FRAGS * PACE_US / 1000000 ))
POINT_TO=$(( SER_S + 240 )); [ "$POINT_TO" -lt 170 ] && POINT_TO=170
echo "dipp-sweep pacing: RATE_BPS=$RATE_BPS -> ~${SER_S}s transmit, point ceiling ${POINT_TO}s"

[ -f "$OUT" ] || echo "arm,loss,seed,label,sent,kept,dropped,realized,observedB,drop_obs,kept_obs,deliv_frac,status" > "$OUT"

for loss in $LOSSES; do
  for seed in $SEEDS; do
    label="sw_L${loss}_s${seed}"
    if awk -F, -v l="$loss" -v s="$seed" '$2==l && $3==s && $13=="ok"{found=1} END{exit !found}' "$OUT"; then
      echo "-- $label already done, skipping"
      continue
    fi
    echo "-- $label : running"
    log=$(RATE_BPS="$RATE_BPS" timeout "$POINT_TO" bash "$REPO/scripts/upload-point" "$loss" "$seed" "$label" 2>&1)
    rc=$?
    echo "$log" | sed 's/^/   /'
    sent=$(echo "$log"    | grep -oE 'sent_unique=[0-9]+'    | cut -d= -f2 | head -1)
    kept=$(echo "$log"    | grep -oE 'kept=[0-9]+'           | cut -d= -f2 | head -1)
    dropped=$(echo "$log" | grep -oE 'dropped=[0-9]+'        | cut -d= -f2 | head -1)
    realized=$(echo "$log"| grep -oE 'realized=[0-9.NA]+'    | cut -d= -f2 | head -1)
    observed=$(echo "$log"| grep -oE 'observed_unique=[0-9]+'| cut -d= -f2 | head -1)
    drop_obs=$(echo "$log"| grep -oE 'dropped&observed=[0-9]+' | cut -d= -f2 | head -1)
    kept_obs=$(echo "$log"| grep -oE 'kept&observed=[0-9]+'  | cut -d= -f2 | head -1)
    if [ $rc -eq 0 ] && [ -n "${kept:-}" ]; then
      frac=$(awk -v k="$kept" -v t="$TOTAL_FRAGS" 'BEGIN{printf "%.4f", k/t}')
      status=ok
    else
      sent=${sent:-}; kept=${kept:-}; dropped=${dropped:-}; realized=${realized:-}
      observed=${observed:-}; drop_obs=${drop_obs:-}; kept_obs=${kept_obs:-}
      frac=""; status="fail_rc$rc"
    fi
    echo "dipp,$loss,$seed,$label,$sent,$kept,$dropped,$realized,$observed,$drop_obs,$kept_obs,$frac,$status" >> "$OUT"
    sleep 3   # settle between points (client kill/spawn, bus drain)
  done
done
echo "== sweep complete: $OUT =="
awk -F, 'NR>1 && $13=="ok"' "$OUT" | wc -l | xargs echo "ok points:"
awk -F, 'NR>1 && $13!="ok"' "$OUT" | wc -l | xargs echo "failed points:"
