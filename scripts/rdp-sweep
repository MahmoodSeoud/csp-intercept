#!/usr/bin/env bash
# rdp-sweep - the RDP/CSH upload arm: forward-loss integrity sweep (RQ3 differential).
#
# Runs rdp-point over (loss x seed) and appends rows to captures/rdp_sweep.csv. The
# headline question: does the RDP+CRC32 upload path EVER report success while
# delivering corrupt bytes (silent corruption)? Hypothesis: never -- it delivers
# intact (crc SUCCESS + sha MATCH) or fails loudly (claimed FAILED). Contrast the
# DTP arms (dipp_sweep.csv / rawdtp_sweep.csv) which corrupt-but-accept under loss.
#
# Usage: rdp-sweep ["0.02 0.05 0.10 0.20 0.30"] [nseeds]
set -uo pipefail
LOSSES="${1:-0.02 0.05 0.10 0.20 0.30}"
NSEEDS="${2:-3}"
PACE_US="${PACE_US:-0}"   # integrity is rate-independent; unpaced for speed
REPO=/home/mseo/thesis/csp-intercept
CSV="$REPO/captures/rdp_sweep.csv"
[ -f "$CSV" ] || echo "loss,seed,injected,dropped,claimed,crc,sha,rate_bps,ts" > "$CSV"
RATE_BPS=$(( PACE_US > 0 ? 256*8*1000000/PACE_US : 0 ))
echo "rdp-sweep: losses=[$LOSSES] nseeds=$NSEEDS pace=${PACE_US}us (rate_bps=${RATE_BPS}, 0=line rate)"
for loss in $LOSSES; do
  for s in $(seq 1 "$NSEEDS"); do
    label="rdp_L${loss}_s${s}"
    line=$(PACE_US="$PACE_US" timeout 800 bash "$REPO/scripts/rdp-point" "$loss" "$s" "$label" 2>&1 | grep '^RESULT ')
    if [ -z "$line" ]; then echo "[$label] no RESULT (skipped/failed)"; continue; fi
    read -r _ l sd inj drp clm crc sha <<<"$line"
    ts=$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo NA)
    echo "$l,$sd,$inj,$drp,$clm,$crc,$sha,$RATE_BPS,$ts" >> "$CSV"
    echo "[$label] -> claimed=$clm crc=$crc sha=$sha (inj=$inj drop=$drp)"
  done
done
echo "=== rdp_sweep.csv ==="; column -t -s, "$CSV" 2>/dev/null || cat "$CSV"
echo "--- silent-corruption check (claimed DELIVERED & crc SUCCESS & sha MISMATCH) ---"
awk -F, 'NR>1 && $5=="DELIVERED" && $6=="SUCCESS" && $7=="MISMATCH"{c++} END{print (c+0)" silent-corruption rows (expected 0 for RDP)"}' "$CSV"
