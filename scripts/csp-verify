#!/usr/bin/env python3
"""csp-verify - did the file arrive intact?

Smallest version of the verify tool from docs/verify-spec.md. Mirrors
`sha256sum -c`: quiet OK on success, loud and specific on failure, exit 0/1.

  csp-verify -c <manifest> <delivered-file>

The manifest is the pinned source spec (captures/*.manifest): it carries the
expected sha256 and byte count. With --source <original> a failure also reports
which bytes differ and writes a <file>.missing.json recovery list (the ranges to
re-request, so you resend the broken part, not the whole file).

Honest by construction: it only states what it can verify. It does not invent a
link-loss number (that needs the wire monitor) and it does not claim the
transport "reported delivered" unless you pass --reported.
"""
import argparse
import hashlib
import json
import os
import sys


def sha256_file(path):
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(1 << 16), b""):
            h.update(chunk)
    return h.hexdigest()


def read_manifest(path):
    """Pull sha256 + byte count out of a captures/*.manifest file."""
    want_sha, want_bytes = None, None
    with open(path) as f:
        for line in f:
            line = line.strip()
            if line.startswith("sha256:"):
                want_sha = line.split(":", 1)[1].strip()
            elif line.startswith("bytes:"):
                want_bytes = int(line.split(":", 1)[1].strip())
    if not want_sha:
        sys.exit(f"csp-verify: no sha256 in manifest {path}")
    return want_sha, want_bytes


def diff_ranges(orig_path, recv_path):
    """Contiguous byte runs where delivered != source. Returns (ranges, n_differ)."""
    with open(orig_path, "rb") as a, open(recv_path, "rb") as b:
        orig, recv = a.read(), b.read()
    ranges, n = [], 0
    start = None
    span = max(len(orig), len(recv))
    for i in range(span):
        bad = i >= len(orig) or i >= len(recv) or orig[i] != recv[i]
        if bad:
            n += 1
            if start is None:
                start = i
        elif start is not None:
            ranges.append({"offset": start, "length": i - start})
            start = None
    if start is not None:
        ranges.append({"offset": start, "length": span - start})
    return ranges, n


def short(h):
    return h[:8] + "…" + h[-6:]


def color(s, c, on):
    return f"\033[{c}m{s}\033[0m" if on else s


def main():
    ap = argparse.ArgumentParser(prog="csp-verify", add_help=True)
    ap.add_argument("-c", "--manifest", required=True, help="source manifest (expected sha256)")
    ap.add_argument("file", help="the delivered file to check")
    ap.add_argument("--source", help="original file; enables byte-diff + recovery list on failure")
    ap.add_argument("--reported", help="what the transport claimed, e.g. 'delivered'")
    ap.add_argument("-v", "--verbose", action="store_true", help="full hashes")
    args = ap.parse_args()

    tty = sys.stdout.isatty()
    name = args.file
    if not os.path.exists(args.file):
        sys.exit(f"csp-verify: no such file: {args.file}")

    want_sha, want_bytes = read_manifest(args.manifest)
    got_sha = sha256_file(args.file)
    got_bytes = os.path.getsize(args.file)

    if got_sha == want_sha:
        print(f"{name}: {color('OK', '32', tty)}")
        if args.verbose:
            print(f"  sha256   {want_sha}")
            print(f"  bytes    {got_bytes}")
        return 0

    # FAILED
    head = "checksum mismatch"
    if args.reported:
        head = f'reported \"{args.reported}\" but file is corrupt'
    print(f"{name}: {color('FAILED', '31', tty)} — {head}")
    exp, rcv = (want_sha, got_sha) if args.verbose else (short(want_sha), short(got_sha))
    print(f"  expected   {exp}")
    print(f"  received   {rcv}")

    if want_bytes is not None and got_bytes != want_bytes:
        print(f"  size       {got_bytes} bytes, expected {want_bytes} (truncated)")

    if args.source:
        if not os.path.exists(args.source):
            sys.exit(f"csp-verify: no such source: {args.source}")
        ranges, n = diff_ranges(args.source, args.file)
        total = want_bytes or got_bytes
        pct = 100.0 * n / total if total else 0.0
        print(f"  corrupt    {n} of {total} bytes differ ({pct:.1f}%), {len(ranges)} ranges")
        out = args.file + ".missing.json"
        with open(out, "w") as f:
            json.dump(
                {"file": name, "expected_sha256": want_sha, "received_sha256": got_sha,
                 "bytes_total": total, "bytes_differ": n, "ranges": ranges},
                f, indent=2,
            )
        print(f"  → re-request: {out}")
    return 1


if __name__ == "__main__":
    sys.exit(main())
