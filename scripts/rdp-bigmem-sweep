#!/usr/bin/env bash
# exp_rdp_sweep.sh - CSH-RDP (CSP RDP + CRC32) integrity sweep under injected forward loss.
#
# THE working RDP experiment. Per loss/seed cell it drives real csh (`upload`/`crc32`/
# `download` over generated .csh init files) at node 5431's flat-RAM `bigmem` region,
# through the ci_inject_bridge loss injector, and checks integrity with TWO oracles:
#   crc32 (mechanism)  +  download-back sha256 vs original (authoritative).
# Silent corruption == claimed DELIVERED & sha MISMATCH (expected: never, for stock RDP).
#
# PREREQ: the oracle node up ->  scripts/bringup-vmem-node
#         broker + injector built (build/tests/e2e/ci_inject_bridge, zmqproxy on 6000/7000).
#
# Usage:  experiments/exp_rdp_sweep.sh [mode] [losses] [nseeds]
#   mode   = stock | tuned | both        (default both)
#   losses = "0.10 0.20 0.30"            (default)
#   nseeds = 3                           (default)
# Stock = csh default RDP. Tuned = "-w 5 -c 120000 -p 1000 -k 250" (completion knobs);
# NOTE tuned generates a retransmit storm that can WEDGE the receiver -> its DELIVERED+
# MISMATCH cells are receiver-hang artifacts, not CRC bypass (see notes/rdp-integrity-finding).
set -uo pipefail
REPO=/home/mseo/thesis/csp-intercept
DRV="$REPO/scripts/rdp-repro-5431"       # per-cell driver (retargeted rdp-point: 5431/bigme)
MODE="${1:-both}"; LOSSES="${2:-0.10 0.20 0.30}"; NSEEDS="${3:-3}"
CSV="$REPO/captures/rdp_bigmem_sweep.csv"
[ -f "$CSV" ] || echo "mode,loss,seed,injected,dropped,claimed,crc,sha,verdict,ts" > "$CSV"

pgrep -f 'vmem_node -c can0 -a 5431' >/dev/null || { echo "FAIL: oracle node down — run scripts/bringup-vmem-node"; exit 1; }
ss -ltn 2>/dev/null | grep -q ':6000' || { echo "FAIL: zmqproxy broker (6000) down"; exit 1; }

modes="$MODE"; [ "$MODE" = both ] && modes="stock tuned"
for mode in $modes; do
  opt=""; [ "$mode" = tuned ] && opt="-w 5 -c 120000 -p 1000 -k 250"
  for loss in $LOSSES; do
    for s in $(seq 1 "$NSEEDS"); do
      label="rdpbig_${mode}_L${loss}_s${s}"
      line=$(RDP_OPT="$opt" UP_TO=120000 timeout 400 bash "$DRV" "$loss" "$s" "$label" 2>&1 | grep '^RESULT ')
      [ -z "$line" ] && { echo "[$label] no RESULT (skipped)"; continue; }
      read -r _ l sd inj drp clm crc sha _rev _fwd <<<"$line"
      vd=OK; [ "$clm" = DELIVERED ] && [ "$sha" = MISMATCH ] && vd="WEDGE_ARTIFACT"
      ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
      echo "$mode,$l,$sd,$inj,$drp,$clm,$crc,$sha,$vd,$ts" >> "$CSV"
      echo "[$label] claimed=$clm crc=$crc sha=$sha (inj=$inj drop=$drp) -> $vd"
    done
  done
done
echo "=== silent-corruption rows (DELIVERED & sha MISMATCH; stock expects 0) ==="
awk -F, 'NR>1 && $6=="DELIVERED" && $8=="MISMATCH"{c++} END{print (c+0)}' "$CSV"
echo "=== $CSV ==="; column -t -s, "$CSV"
