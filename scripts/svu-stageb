#!/usr/bin/env bash
# svu-stageb - Stage B: SVU over a HALF-DUPLEX link, where reverse ACKs/re-requests cost
# airtime (unlike Stage A's free return path). The injector's single-threaded pump charges
# every crossing its on-air time at HD_RATE bps, both directions -> one frame on the channel
# at a time = half-duplex. Metric: time-to-complete + reverse-frame airtime vs loss. This is
# where SVU's BATCHED selective-resume (few reverse frames/round) should stay cheap while a
# chatty per-packet-ACK protocol would pay in reverse airtime.
#
# host-to-host: server -z(25) -> zmq broker -> injector(hd) -> can0 -> client(26). data dropped
# on dport 9; ctrl/re-requests (port 11) return clean but now COST airtime.
# Usage: svu-stageb ["0 0.05 0.10 0.20"] [nseeds] [hd_rate_bps] [payload_bytes]
set -uo pipefail
LOSSES="${1:-0 0.05 0.10 0.20}"; NSEEDS="${2:-2}"; HD="${3:-19200}"; PBYTES="${4:-65536}"
REPO=/home/mseo/thesis/csp-intercept
INJ="$REPO/build/tests/e2e/ci_inject_bridge"; SRV="$REPO/build-fe/svu/svu_server"; CLI="$REPO/build-fe/svu/svu_client"
IN=/tmp/stageb_payload.bin; [ "$(stat -c%s "$IN" 2>/dev/null || echo 0)" = "$PBYTES" ] || head -c "$PBYTES" /dev/urandom > "$IN"
IN_SHA=$(sha256sum "$IN" | cut -d' ' -f1)
ss -ltn 2>/dev/null | grep -q ':6000' || { echo "FAIL: broker 6000 down"; exit 1; }
CSV="$REPO/captures/svu_stageb.csv"
[ -f "$CSV" ] || echo "loss,seed,hd_bps,secs,rounds,fwd,drops,rev_frames,sha,ts" > "$CSV"
echo "svu-stageb: payload=${PBYTES}B hd=${HD}bps losses=[$LOSSES] nseeds=$NSEEDS"
for loss in $LOSSES; do
  for s in $(seq 1 "$NSEEDS"); do
    L="sb_L${loss}_s${s}"; ORA="$REPO/captures/${L}_oracleA.csv"; OUT="/tmp/${L}_out.bin"; rm -f "$OUT"
    pkill -x svu_server 2>/dev/null; pkill -f 'tests/e2e/ci_inject_bridge' 2>/dev/null; sleep 0.5
    "$SRV" -z 127.0.0.1 -a 25 -f "$IN" -b 4096 >/tmp/${L}_srv.log 2>&1 &
    for i in $(seq 1 60); do grep -q serving /tmp/${L}_srv.log 2>/dev/null && break; sleep 0.1; done
    "$INJ" zmq:tcp://127.0.0.1:6000,tcp://127.0.0.1:7000,26 can:can0 9 200 8 "$loss" 4 "$s" "$ORA" 25 0 "$HD" >/tmp/${L}_inj.log 2>&1 &
    IP=$!; sleep 2
    t0=$(date +%s.%N)
    out=$(timeout 600 "$CLI" -c can0 -a 26 -C 25 -o "$OUT" -b 4096 -m 200 2>&1)
    t1=$(date +%s.%N)
    kill "$IP" 2>/dev/null; wait "$IP" 2>/dev/null || true; pkill -x svu_server 2>/dev/null
    rounds='?'; echo "$out" | grep -qE "VERIFIED $PBYTES bytes" && rounds=$(echo "$out"|grep -oE 'in [0-9]+ round'|grep -oE '[0-9]+'|head -1)
    got=$(sha256sum "$OUT" 2>/dev/null|cut -d' ' -f1); sha=MISMATCH; [ "$got" = "$IN_SHA" ] && sha=MATCH
    rev=$(grep -oE 'reverse_frames=[0-9]+' /tmp/${L}_inj.log | grep -oE '[0-9]+' | tail -1)
    fwd=$(grep -oE 'forwarded=[0-9]+' /tmp/${L}_inj.log | grep -oE '[0-9]+' | tail -1)
    drp=$(grep -oE 'injected_drops=[0-9]+' /tmp/${L}_inj.log | grep -oE '[0-9]+' | tail -1)
    secs=$(awk -v a="$t0" -v b="$t1" 'BEGIN{printf "%.1f", b-a}')
    ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    echo "$loss,$s,$HD,$secs,${rounds:-?},${fwd:-0},${drp:-0},${rev:-0},$sha,$ts" >> "$CSV"
    echo "[$L] secs=$secs rounds=${rounds:-?} rev_frames=${rev:-0} fwd=${fwd:-0} drops=${drp:-0} sha=$sha"
  done
done
echo "=== svu_stageb.csv ==="; column -t -s, "$CSV"
