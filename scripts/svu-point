#!/usr/bin/env bash
# svu-point - ONE cell of the Self-Verifying Uploader (SVU) forward-loss arm.
#
# The SVU is the corrected DTP: a fire-and-forget bulk data plane (port 9, no
# per-packet CRC) PLUS a per-block integrity manifest and a verified-completion
# handshake (control port 11, RDP+CRC32). The client accepts a block only if its
# bytes hash to the manifest entry, and re-requests the still-missing/corrupt
# ranges each round. Hypothesis: under forward loss the SVU NEVER reports success
# on wrong bytes -- it delivers VERIFIED (every block hash matches -> sha MATCH by
# construction) or gives up loudly. Contrast the raw DTP data plane (rawdtp/dipp
# arms), which under the same loss reports DELIVERED while writing a corrupt file.
#
# Wiring (host-only, mirrors rdp-point but no board): svu_server on zmq(25) ->
# zmqproxy-lossy (6000/7000) -> ci_inject_bridge (drops forward SVU data frames on
# dport=9) -> can0 -> svu_client on can0(26). Control/re-request frames (from 26,
# != src_addr) return CLEAN out the ingress, so this measures forward data loss with
# a free ACK path -- Stage A. (Stage B makes ACKs cost airtime; separate driver.)
#
# Per cell: pull the pinned 256 KiB payload through the lossy injector; the client
# self-verifies against the manifest. Then an EXTERNAL oracle (sha256 of the written
# file vs the original) confirms the self-verification did not lie.
#
# Output (last line): RESULT <loss> <seed> <injected> <dropped> <claimed> <rounds> <sha>
#   claimed = VERIFIED (client printed "VERIFIED <n> bytes") | INCOMPLETE (gave up/timeout)
#   rounds  = rounds the client needed (from "in <r> round(s)"), or ? if incomplete
#   sha     = MATCH | MISMATCH   (written file vs original, AUTHORITATIVE external oracle)
#   SILENT CORRUPTION == claimed VERIFIED & sha MISMATCH. Expected: never.
# Usage: svu-point <loss> <seed> <label>     e.g.  svu-point 0.10 7 svu_L0.10_s7
set -uo pipefail
LOSS="${1:?loss}"; SEED="${2:?seed}"; LABEL="${3:?label}"
SRV_ADDR="${SRV_ADDR:-25}"; CLI_ADDR="${CLI_ADDR:-26}"; DPORT="${DPORT:-9}"
MTU="${MTU:-200}"; OVH="${OVH:-8}"; BLOCK="${BLOCK:-4096}"; BURST="${BURST:-4}"; PACE_US="${PACE_US:-0}"
REPO=/home/mseo/thesis/csp-intercept
CAP="$REPO/captures"; PAY="$CAP/payload_256k.bin"
SIZE=$(stat -c%s "$PAY"); ORIG_SHA=$(awk '/sha256:/{print $2}' "$CAP/payload_256k.manifest")
INJ="$REPO/build/tests/e2e/ci_inject_bridge"
SRV="$REPO/build-fe/svu/svu_server"; CLI="$REPO/build-fe/svu/svu_client"

# preflight
ss -ltn 2>/dev/null | grep -q ':6000' || { echo "FAIL: zmqproxy broker (6000) down"; exit 1; }
[ -x "$INJ" ] || { echo "FAIL: injector not built at $INJ"; exit 1; }
[ -x "$SRV" ] && [ -x "$CLI" ] || { echo "FAIL: svu binaries missing (build -Dfrontends=true)"; exit 1; }
if pgrep -f 'tests/e2e/ci_inject_bridge' >/dev/null 2>&1; then echo "FAIL: a ci_inject_bridge already running"; exit 1; fi
pkill -x svu_server 2>/dev/null; sleep 0.5

OUT="/tmp/${LABEL}_out.bin"; SRVLOG="/tmp/${LABEL}_srv.log"; CLILOG="/tmp/${LABEL}_cli.log"
ORA="$CAP/${LABEL}_oracleA.csv"; rm -f "$OUT"

# 1) server (data source, addr SRV_ADDR) on the lossy broker, serving the pinned payload
"$SRV" -z 127.0.0.1 -a "$SRV_ADDR" -f "$PAY" -b "$BLOCK" >"$SRVLOG" 2>&1 &
SRVPID=$!
for _i in $(seq 1 60); do grep -q serving "$SRVLOG" 2>/dev/null && break; sleep 0.1; done
echo "[$LABEL] size=$SIZE loss=$LOSS seed=$SEED mtu=$MTU block=$BLOCK burst=$BURST pace=${PACE_US}us"

# 2) lossy injector (forward SVU-data drops on dport=DPORT), active for the whole pull
"$INJ" zmq:tcp://127.0.0.1:6000,tcp://127.0.0.1:7000,"$CLI_ADDR" can:can0 \
    "$DPORT" "$MTU" "$OVH" "$LOSS" "$BURST" "$SEED" "$ORA" "$SRV_ADDR" "$PACE_US" \
    >"/tmp/${LABEL}_inj.log" 2>&1 &
INJPID=$!; sleep 3

# 3) lossy pull via zmq(SRV) -> injector -> can0 -> client(CLI_ADDR)
timeout 600 "$CLI" -c can0 -a "$CLI_ADDR" -C "$SRV_ADDR" -o "$OUT" -b "$BLOCK" -m "$MTU" >"$CLILOG" 2>&1
rc=$?
claimed=INCOMPLETE; rounds='?'
if grep -qE "VERIFIED $SIZE bytes" "$CLILOG"; then
  claimed=VERIFIED
  rounds=$(grep -oE "in [0-9]+ round" "$CLILOG" | grep -oE "[0-9]+" | head -1)
fi

kill "$INJPID" 2>/dev/null; wait "$INJPID" 2>/dev/null || true
kill "$SRVPID" 2>/dev/null; wait "$SRVPID" 2>/dev/null || true
pkill -x svu_server 2>/dev/null

inj=$(awk -F, '!/^#/{c++} END{print c+0}' "$ORA" 2>/dev/null)
drop=$(awk -F, '!/^#/ && $8==1{c++} END{print c+0}' "$ORA" 2>/dev/null)

# 4) EXTERNAL oracle: sha256 of the written file vs the original (authoritative)
got_sha=$(sha256sum "$OUT" 2>/dev/null | cut -d' ' -f1)
sha=MISMATCH; [ "$got_sha" = "$ORIG_SHA" ] && sha=MATCH

verdict=OK
[ "$claimed" = VERIFIED ] && [ "$sha" = MISMATCH ] && verdict="*** SILENT CORRUPTION ***"
echo "[$LABEL] claimed=$claimed rounds=${rounds:-?} sha=$sha injected=$inj dropped=$drop rc=$rc  $verdict"
echo "RESULT $LOSS $SEED $inj $drop $claimed ${rounds:-?} $sha"
