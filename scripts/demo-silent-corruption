#!/usr/bin/env bash
# demo-silent-corruption - a screen-recordable proof that a CubeSat file-transfer
# protocol reports SUCCESS while delivering a CORRUPTED file under link loss.
#
# It replays REAL artifacts captured from actual transfer runs and re-verifies
# them LIVE on screen. Nothing is pre-computed: hashes are recomputed in front of
# the camera from bytes on disk. Fixtures are committed under demo/fixtures/, so
# anyone who clones the repo can reproduce this exactly.
#
# WHO WROTE THE CODE UNDER TEST (so nobody can say "you just wrote a bad uploader"):
#   The failure lives in libdtp's transfer/resume/completion path. Two facts,
#   both verifiable:
#     1. git blame attributes that code to Space Inventor engineers, not us.
#     2. The buggy mechanism (dtp_protocol.c read_remote_meta_resp + the
#        compute_nof_packets truncation) is BYTE-IDENTICAL in upstream
#        spaceinventor/libdtp -- it is not an artifact of the DISCO fork.
#        (Diff: fork vs upstream differ only in an errno field name and an
#        unrelated metrics helper; the failure path is the same source.)
#   The only code we add is a loss injector that drops CSP frames. Nothing of
#   ours touches the file bytes or the "transfer complete" decision.
#
# SAFETY: pure file I/O. No daemons, no network, no can0, no hardware.
#
# Usage:  scripts/demo-silent-corruption            # default 10% loss case
#         LOSS=0.30 scripts/demo-silent-corruption  # 0.05/0.10/0.20/0.30
#         NOPAUSE=1 scripts/demo-silent-corruption  # straight-through (no prompts)
set -uo pipefail

REPO="$(cd "$(dirname "$0")/.." && pwd)"
# Prefer committed fixtures (reproducible anywhere); fall back to live captures/.
FIX="$REPO/demo/fixtures"; [ -f "$FIX/payload_256k.bin" ] || FIX="$REPO/captures"
LOSS="${LOSS:-0.10}"; SEED="${SEED:-1}"
ORIG="$FIX/payload_256k.bin"
RECV="$FIX/dtp_L${LOSS}_s${SEED}_received.bin"; [ -f "$RECV" ] || RECV="$FIX/dtp_L0.10_s1_received.bin"
CLEAN="$FIX/dtp_L0_s1_received.bin"
VLOG="$FIX/h2_iso_L0.10_s1_resume_pass2.log"
SWEEP="$FIX/rawdtp_sweep.csv"
RQ3="$FIX/rq3_corruption.csv"

bold=$'\e[1m'; grn=$'\e[32m'; red=$'\e[31m'; ylw=$'\e[33m'; cyn=$'\e[36m'; rst=$'\e[0m'
step(){ printf '\n%s=== %s ===%s\n' "$bold$cyn" "$1" "$rst"; }
pause(){ [ -n "${NOPAUSE:-}" ] && return; printf '%s   (press enter)%s' "$ylw" "$rst"; read -r _ </dev/tty || true; }
sha(){ sha256sum "$1" | cut -d' ' -f1; }

for f in "$ORIG" "$RECV" "$CLEAN" "$VLOG" "$RQ3"; do
  [ -f "$f" ] || { echo "${red}missing artifact: $f${rst}"; exit 1; }
done

clear 2>/dev/null || true
cat <<EOF
${bold}Does 'upload complete' mean the file actually arrived?${rst}
A CubeSat file-transfer protocol (Space Inventor's DTP) moved a 256 KiB image
over a link with packet loss injected. Below: what the protocol reported, vs.
what actually landed. Every hash is computed live, now, from disk.
EOF

step "STEP 1  The headline: this is systematic, and it is by design"
echo "The deployed fire-and-forget receiver has NO end-to-end integrity check"
echo "(connectionless DTP, like UDP). Result across a loss sweep (rq3_corruption.csv):"
echo
awk -F, 'NR==1{next}
  {tot++; if($6=="no"){bad++}}
  END{
    printf "   lossy runs that delivered CORRUPT bytes but reported SUCCESS: %d\n", bad;
    printf "   clean (0%%-loss) runs that were correct: %d\n", tot-bad;
  }' "$RQ3"
echo "   ${bold}Every lossy transfer: wrong bytes, reported success. Every clean one: correct.${rst}"
echo "   This is not a bug in one build -- it is what happens with no integrity check."
pause

step "STEP 2  The file we uploaded (ground truth)"
echo "path   : $ORIG"
echo "size   : $(stat -c%s "$ORIG") bytes"
printf "sha256 : %s%s%s\n" "$bold" "$(sha "$ORIG")" "$rst"
pause

step "STEP 3  Even the OBVIOUS FIX (resume) silently corrupts -- vendor's own log"
echo "You'd think 'turn on resume' fixes it. Here is the vendor client's resume log:"
echo "(from $(basename "$VLOG"))"
sed 's/\r//g' "$VLOG" | grep -E 'Setting session total|Missing:|Missing intervals' \
  | sed -E "s/.*(Setting session total bytes to [0-9]+).*/   ${ylw}\1${rst}  <- garbage: file is 256 KiB, not 3.5 GB/; s/.*(Missing: 0)\$/   ${grn}\1${rst}  <- reports COMPLETE/; s/.*(Missing intervals: [0-9]+).*/   ${red}\1${rst}  <- ...but 18 intervals never arrived/"
echo
echo "   ${bold}Reports 'Missing: 0' while 18 intervals never arrived. This mechanism${rst}"
echo "   ${bold}is byte-identical in upstream spaceinventor/libdtp -- not a fork bug.${rst}"
pause

step "STEP 4  What actually landed after that 'complete' (recompute the hash live)"
echo "path   : $RECV"
echo "size   : $(stat -c%s "$RECV") bytes   ${bold}(exactly right size -- nothing looks wrong)${rst}"
printf "sha256 : %s%s%s\n" "$bold" "$(sha "$RECV")" "$rst"
echo "expected: $(sha "$ORIG")"
echo
if cmp -s "$ORIG" "$RECV"; then
  printf "%s   MATCH${rst}\n" "$grn$bold"
else
  ndiff=$(cmp -l "$ORIG" "$RECV" 2>/dev/null | wc -l | tr -d ' ')
  firstb=$(cmp "$ORIG" "$RECV" 2>&1 | sed -E 's/.*byte ([0-9]+).*/\1/')
  printf "%s   >>> SHA-256 MISMATCH -- the delivered file is CORRUPT <<<%s\n" "$red$bold" "$rst"
  echo "   right size, wrong bytes: ${red}${ndiff} bytes differ${rst}, first at byte ${firstb}."
  echo "   ${red}The protocol reported COMPLETE. Nothing warned the operator.${rst}"
fi
pause

step "STEP 5  Control: same protocol, ZERO loss (proves it's the loss, not the rig)"
echo "clean-run received sha256 : ${bold}$(sha "$CLEAN")${rst}"
echo "original          sha256 : ${bold}$(sha "$ORIG")${rst}"
cmp -s "$ORIG" "$CLEAN" \
  && printf "%s   MATCH -- with no loss the same protocol delivers perfectly.%s\n" "$grn$bold" "$rst" \
  || printf "%s   (unexpected: clean run mismatched)%s\n" "$red" "$rst"
echo
cat <<EOF
${bold}Bottom line${rst}
  - Vendor client + vendor server. The 'complete' decision and the bytes are vendor code.
  - Fire-and-forget corrupts silently by design; resume corrupts silently via a real
    upstream bug. Both report success. Neither warns the operator.
  - With zero loss it is perfect -- so this is silent, loss-induced corruption.
  - Catching it needs an external integrity check under injected loss. That is the product.
EOF
