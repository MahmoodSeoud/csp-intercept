#!/usr/bin/env bash
#
# sweep - drive the can0 two-oracle bench across a loss range and aggregate the results
# into a loss-vs-delivery curve (T4, the parametric burst-loss sweep).
#
# For each (loss x seed) it runs scripts/can0-bench (the real-hardware two-oracle), parses
# the RESULT block, and appends a row to captures/sweep_<proto>.csv. The headline column is
# delivered_frac = observed/sent (goodput proxy); `agree` must be PASS at every point or the
# measurement at that point is untrustworthy. A per-run timeout keeps a hung transfer from
# stalling the whole sweep.
#
# Usage:
#   scripts/sweep                       # dtp, losses 0/0.05/0.1/0.2/0.3, seeds 1 2 3, burst 4
#   scripts/sweep rdp                   # RDP instead of DTP
#   LOSSES="0 0.1 0.3" SEEDS="1" scripts/sweep dtp 4   # custom range, burst 4
set -uo pipefail
cd "$(dirname "$0")/.."

PROTO="${1:-dtp}"
BURST="${2:-4}"
LOSSES="${LOSSES:-0 0.05 0.1 0.2 0.3}"
SEEDS="${SEEDS:-1 2 3}"
PER_RUN_TIMEOUT="${PER_RUN_TIMEOUT:-150}"

mkdir -p captures
OUT="captures/sweep_${PROTO}.csv"
echo "proto,loss,seed,burst,sent,dropped,kept,observed,overlap,delivered_frac,agree" > "$OUT"

echo "== sweep: $PROTO  losses=[$LOSSES]  seeds=[$SEEDS]  burst=$BURST  -> $OUT =="
for loss in $LOSSES; do
  for seed in $SEEDS; do
    printf -- "-- loss=%s seed=%s ... " "$loss" "$seed"
    # Per-run timeout: a transfer that hangs under high loss must not stall the sweep.
    log="$(timeout "$PER_RUN_TIMEOUT" scripts/can0-bench "$PROTO" "$loss" "$seed" "$BURST" 2>&1)" || true

    ra="$(printf '%s\n' "$log" | grep 'oracle A' || true)"
    dropped="$(printf '%s' "$ra"   | grep -oP 'dropped \K[0-9]+'   || echo NA)"
    kept="$(printf '%s' "$ra"      | grep -oP 'kept \K[0-9]+'      || echo NA)"
    sent="$(printf '%s' "$ra"      | grep -oP 'of \K[0-9]+'        || echo NA)"
    observed="$(printf '%s\n' "$log" | grep 'oracle B' | grep -oP 'observed \K[0-9]+' || echo NA)"
    overlap="$(printf '%s\n' "$log"  | grep 'dropped-and-observed' | grep -oP ': \K[0-9]+' || echo NA)"
    # Two-oracle agreement is judged from the oracle data, NOT can0-bench's pass-string
    # (which is INCONCLUSIVE at loss=0 by design: it gates on >=10 drops). The real
    # invariant is overlap==0 (no dropped frame observed) AND the kept frames were observed
    # (coverage >=80%, allowing slow-joiner at stream start). This makes the 0% control PASS.
    agree=FAIL
    if [ "$overlap" = "0" ] && [ "$observed" != "NA" ] && [ "$kept" != "NA" ]; then
      need=$(( kept * 80 / 100 ))
      if [ "$observed" -ge "$need" ]; then agree=PASS; fi
    fi
    frac="$(awk -v o="$observed" -v s="$sent" 'BEGIN{ if (s ~ /^[0-9]+$/ && s+0>0) printf "%.4f", o/s; else printf "NA" }')"

    echo "$PROTO,$loss,$seed,$BURST,$sent,$dropped,$kept,$observed,$overlap,$frac,$agree" >> "$OUT"
    printf "sent=%s dropped=%s observed=%s overlap=%s frac=%s [%s]\n" \
           "$sent" "$dropped" "$observed" "$overlap" "$frac" "$agree"
  done
done

echo ""
echo "== curve ($OUT) =="
if command -v column >/dev/null 2>&1; then column -t -s, "$OUT"; else cat "$OUT"; fi

# Fail loud if any point's two oracles disagreed (the measurement there is not trustworthy).
if grep -q ',FAIL$' "$OUT"; then
  echo ""; echo "WARNING: one or more points FAILED two-oracle agreement -- those rows are untrustworthy."
  exit 1
fi
echo ""; echo "sweep: all points agree (two-oracle PASS)."
