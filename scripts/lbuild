#!/usr/bin/env bash
#
# lbuild - build + test the Linux-only front-ends (proxy + monitor APM) in a
# container. libcsp/CSH do not build on macOS host, so this is the local dev loop
# on a mac (and mirrors CI). The pure lib (lib/ + tests/) builds natively with
# plain `meson test`; this script is only for the -Dfrontends=true targets.
#
# Usage:
#   scripts/lbuild            # setup (if needed) + compile + test
#   scripts/lbuild clean      # drop the persistent build volume, then build
#
# The build dir lives in a named docker volume (csp-intercept-build) so libcsp is
# compiled once and rebuilds are incremental. The repo is mounted read/write at
# /work; only source files are touched on the host.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
IMG="csp-intercept-dev"
VOL="csp-intercept-build"

cd "$REPO_ROOT"

if [ "${1:-}" = "clean" ]; then
  docker volume rm "$VOL" >/dev/null 2>&1 || true
  echo "lbuild: removed build volume $VOL"
fi

echo "lbuild: building image $IMG (cached after first run)..."
docker build -q -t "$IMG" -f docker/Dockerfile . >/dev/null

echo "lbuild: compiling + testing front-ends in container..."
docker run --rm \
  -v "$REPO_ROOT":/work -w /work \
  -v "$VOL":/build \
  "$IMG" bash -lc '
    set -e
    git config --global --add safe.directory "*" 2>/dev/null || true
    if [ ! -f /build/bl/build.ninja ]; then
      meson setup /build/bl /work -Dfrontends=true
    else
      meson setup /build/bl /work --reconfigure -Dfrontends=true >/dev/null
    fi
    meson compile -C /build/bl
    meson test -C /build/bl --print-errorlogs
  '
